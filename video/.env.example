# Copy to video/.env (gitignored) and fill in your two ElevenLabs values.
ELEVENLABS_API_KEY=sk-...your key...
ELEVENLABS_VOICE_ID=your_cloned_voice_id_here

# Expanded in episode script.yaml actions:
ASSETS=./assets               # local title/diagram HTML cards
CONTROLLER_IP=127.0.0.1       # dashboards if/when an episode exposes one
